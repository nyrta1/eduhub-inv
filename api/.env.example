# Copy this file to `.env` before running Docker Compose or local tooling.
# Never commit real secrets.

APP_ENV=development
APP_DEBUG=false
APP_NAME=student-platform-api

# Minimum 32 characters. Generate with:
#   openssl rand -hex 32   (POSIX shells)
#   [Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
APP_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

API_HOST=0.0.0.0
API_PORT=8000

# Trusted hosts for TrustedHostMiddleware (comma-separated).
API_ALLOWED_HOSTS=localhost,127.0.0.1,api

# Comma-separated browser origins; leave empty to disable CORS middleware entirely.
CORS_ALLOWED_ORIGINS=

# Async SQLAlchemy URL (must include +asyncpg or +psycopg async driver).
DATABASE_URL=postgresql+asyncpg://app_user:app_password@postgres:5432/app_db

DATABASE_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

REDIS_URL=redis://redis:6379/0

LOG_LEVEL=INFO
LOG_JSON=true
STRUCTLOG_CALLER_INFO=false

# Forward structured logs to Logstash HTTP input (ensure Logstash is healthy first).
LOG_SHIP_LOGSTASH=false
LOGSTASH_HTTP_ENDPOINT=http://logstash:5044/

METRICS_ENABLED=true
METRICS_PATH=/metrics

REQUEST_MAX_BODY_BYTES=1048576

JWT_ISSUER=student-platform-api
JWT_AUDIENCE_ACCESS=student-platform-access
JWT_AUDIENCE_REFRESH=student-platform-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_ALGORITHM=HS256

# Optional overrides (otherwise APP_SECRET_KEY is used)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
TOKEN_PEPPER=

PASSWORD_HISTORY_LIMIT=5
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_SECONDS=900
AUTH_LOGIN_MAX_PER_IP_PER_MINUTE=30
AUTH_LOGIN_MAX_PER_EMAIL_PER_MINUTE=15
AUTH_REGISTER_MAX_PER_IP_PER_HOUR=10
AUTH_REFRESH_MAX_PER_SESSION_PER_MINUTE=30

# Stage 4 security hardening (see SECURITY.md)
SECURITY_EXPOSE_OPENAPI=false
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_PERMISSIONS_POLICY=accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_CACHE_CONTROL_SENSITIVE=no-store, no-cache, must-revalidate, private
API_ACADEMIC_APPLICATION_SUBMIT_PER_IP_PER_HOUR=60
API_ACADEMIC_GRADE_WRITE_PER_IP_PER_MINUTE=120
API_ACADEMIC_GRADE_WRITE_PER_TOKEN_PER_MINUTE=60
API_ADMIN_ROLE_CHANGE_PER_IP_PER_HOUR=40
API_APPLICATION_REVIEW_PER_IP_PER_MINUTE=200
SECURITY_DENIED_BURST_THRESHOLD_PER_IP=25
SECURITY_DENIED_BURST_WINDOW_SECONDS=120
SECURE_HTTP_DEFAULT_TIMEOUT_SECONDS=10

POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=app_db
POSTGRES_PORT=5432

REDIS_PORT=6379

PROMETHEUS_PORT=9090

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me
GRAFANA_PORT=3000
GRAFANA_ROOT_URL=http://localhost:3000

ELASTICSEARCH_PORT=9200
LOGSTASH_HTTP_PORT=5044
KIBANA_PORT=5601
